{
  "name": "qr-studio",
  "version": "1.0.0",
  "description": "Professional QR Code Generator - Desktop App",
  "main": "electron/main.js",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:electron": "npm run build:web && electron-builder",
    "build:win": "npm run build:web && electron-builder --win",
    "build:portable": "npm run build:web && electron-builder --win --portable",
    "start": "electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0",
    "qrcode-generator": "^1.4.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^4.4.0",
    "electron": "^latest",
    "electron-builder": "^24.6.0",
    "electron-is-dev": "^2.0.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  },
  "build": {
    "appId": "com.qr-studio.app",
    "productName": "QR Studio",
    "directories": {
      "buildResources": "build",
      "output": "dist/electron"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "electron/preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "certificateFile": null,
      "certificatePassword": null,
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "QRStudio-${version}-portable.exe"
    }
  }
}
